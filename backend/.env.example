# Copy this file to .env and fill in your keys

# Khaya AI (https://ghananlp.org — Translation, ASR, TTS for Ghanaian languages)
KHAYA_API_KEY=your_khaya_api_key_here

# LLM — Anthropic Claude (recommended) or OpenAI GPT
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here  # only needed if using GPT as LLM

# Which LLM to use: "claude" or "openai"
LLM_PROVIDER=claude

# Embeddings are handled locally via sentence-transformers (all-MiniLM-L6-v2)
# No API key required for embeddings.
