# Copy this file to .env and fill in your keys

# Khaya AI (https://ghananlp.org — Translation, ASR, TTS for Ghanaian languages)
KHAYA_API_KEY=your_khaya_api_key_here

# LLM — use ONE of the following:
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Embeddings (OpenAI embeddings recommended for FAISS index)
OPENAI_API_KEY=your_openai_api_key_here

# Which LLM to use: "claude" or "openai"
LLM_PROVIDER=claude

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small
