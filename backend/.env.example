# Copy this file to .env and fill in your keys

# Khaya AI — subscribe & keys at https://translation.ghananlp.org (portal). Calls go to the API gateway below.
KHAYA_API_KEY=your_khaya_api_key_here
# Optional: KHAYA_PRIMARY_KEY= / KHAYA_SECONDARY_KEY= (Azure APIM rotation)

# API gateway (portal host translation.ghananlp.org returns 404 for /v1/translate, /tts/… — do not use it for requests)
# KHAYA_BASE_URL=https://translation-api.ghananlp.org

# Optional full URL overrides (default: {KHAYA_BASE_URL}/tts/v1/synthesize and …/asr/v1/transcribe)
# KHAYA_TTS_URL=https://translation-api.ghananlp.org/tts/v1/synthesize
# KHAYA_ASR_URL=https://translation-api.ghananlp.org/asr/v1/transcribe

# TTS speaker_id from GET …/tts/v1/speakers — must match language (twi_* only with Twi, ewe_* with Ewe).
# Global KHAYA_TTS_SPEAKER_ID applies only when the id fits the request (e.g. twi_speaker_6 is used for ``language: tw`` only; Ewe replies use defaults or KHAYA_TTS_SPEAKER_ID_EE).
# KHAYA_TTS_SPEAKER_ID=twi_speaker_6
# KHAYA_TTS_SPEAKER_ID_EE=ewe_speaker_4
# Legacy alias (same as KHAYA_TTS_SPEAKER_ID):
# KHAYA_TTS_SPEAKER=

# Optional performance tuning (faster failover / snappier UX in local dev).
# Uncomment to reduce long waits during upstream slowness.
# API_RETRY_ATTEMPTS=3
# API_RETRY_BASE_DELAY=1.0
# KHAYA_TRANSLATE_TIMEOUT=75
# KHAYA_TTS_TIMEOUT=90

# LLM — Anthropic Claude (recommended) or OpenAI GPT
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here  # only needed if using GPT as LLM

# Which LLM to use: "claude" or "openai"
LLM_PROVIDER=claude

# Embeddings are handled locally via sentence-transformers (all-MiniLM-L6-v2)
# No API key required for embeddings.
