# Production: set `VITE_API_BASE_URL` in the Vercel project (Environment Variables) for Production and Preview.
# Use your backend deployment root including `/api`, for example:
# VITE_API_BASE_URL=https://oboafo-api.vercel.app/api
#
# Local dev: leave unset to use `/api` (Vite proxy to http://localhost:8000).

# VITE_API_BASE_URL=

# TTS: Khaya via POST /api/tts (default on). Set to false to use only the browser voice.
#VITE_TTS_USE_KHAYA=true
# If Khaya fails, fall back to Web Speech (default true). Set false to surface errors only.
# VITE_TTS_BROWSER_FALLBACK=true
# English UI has no Khaya "en" voice — we use Twi engine unless set to none|false for Web Speech only.
#VITE_TTS_KHAYA_VOICE_FOR_EN=tw
# Max chars per Khaya TTS chunk for long responses (default 300, safe range 120..450).
# VITE_TTS_KHAYA_CHUNK_CHARS=300
